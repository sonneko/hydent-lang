type NodePtr<T> = ClassNode<T>;

class ClassNode<T> {
    pub val: T;
    pub next: ?NodePtr<T>;

    pub fn new(v: T) : ClassNode<T> {
        return ClassNode { val: v, next: None };
    }
}

fn length<T>(node: ?NodePtr<T>) : Int {
    return match node {
        Some(n) => 1 + length(n.next),
        None => 0,
    };
}

fn main() {
    let mut head = ClassNode::new(10);
    let second = ClassNode::new(20);
    head.next = Some(second);

    let len = length(Some(head));
    print(len);
}
