fn find_in_matrix(matrix: Vec<Vec<Int>>, target: Int) : Bool {
    let found = loop "search" {
        for row in matrix {
            for val in row {
                if val == target {
                    break "search" true;
                }
            }
        }
        break false;
    };
    return found;
}

fn main() {
    let data = vec(vec(1, 2), vec(3, 4));
    if find_in_matrix(data, 3) {
        print("Found");
    }
}
