{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "DSL Grammar",
	"scopeName": "source.dsl",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#definitions"
		},
		{
			"include": "#properties"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#operators"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.dsl",
					"match": "//.*$"
				}
			]
		},
		"definitions": {
			"patterns": [
				{
					"comment": "product または branch の定義名",
					"match": "\\b(product|branch)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": {
							"name": "keyword.other.definition.dsl"
						},
						"2": {
							"name": "entity.name.type.dsl"
						}
					}
				}
			]
		},
		"properties": {
			"patterns": [
				{
					"comment": "name: type の形式",
					"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)\\s*([\\?\\*])?([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": {
							"name": "variable.other.property.dsl"
						},
						"2": {
							"name": "keyword.operator.assignment.dsl"
						},
						"3": {
							"name": "keyword.operator.quantifier.dsl"
						},
						"4": {
							"name": "storage.type.dsl"
						}
					}
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.dsl",
					"match": "\\b(with|as|import|from)\\b"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.dsl",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.dsl",
					"match": "\\\\."
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.quantifier.dsl",
					"match": "[\\?\\*]"
				},
				{
					"name": "punctuation.section.braces.dsl",
					"match": "[\\{\\}]"
				}
			]
		}
	}
}