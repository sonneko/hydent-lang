{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "tibineko",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.tibineko",
				"match": "\\b(branch|product|with)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.double.tibineko",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.tibineko",
					"match": "\\\\."
				}
			]
		},
		"operator": {
			"patterns": [{
				"name": "operator.control.tibineko",
				"match": "\\b(?|*|:)\\"
			}]
		}
	},
	"scopeName": "source.tibineko"
}